/* Main website setup */
body {
    background-color: #ffffff;
    color: #111111;
    font-family: Arial, Helvetica, sans-serif;
    margin: 0;
    padding: 0;
}

/* Remove default link underline */
a {
    text-decoration: none;
}

/* Premium navbar */
.custom-navbar {
    background-color: #ffffff;
    border-bottom: 1px solid #e5e5e5;
    padding: 18px 0;
}

/* Navbar links */
.custom-navbar .nav-link {
    color: #111111;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 0 8px;
}

/* South African inspired subtle hover colours */
.custom-navbar .nav-link:hover {
    color: #007a4d;
}

/* Center logo area */
.navbar-logo {
    font-size: 20px;
    font-weight: 800;
    letter-spacing: 2px;
    color: #111111;
    text-transform: uppercase;
}

/* Logo wrapper */
.navbar-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto;
    padding: 0;
    min-height: 60px;
}

/* Logo image */
.logo-img {
    display: block;
    height: 60px;
    width: auto;
    max-width: 240px;
    object-fit: contain;
}

/* Mobile logo */
@media (max-width: 768px) {
    .logo-img {
        height: 45px;
        max-width: 170px;
    }
}

/* Hero section */
.hero-section {
    padding: 80px 0;
    text-align: center;
}

/* Hero heading */
.hero-title {
    font-size: 56px;
    font-weight: 800;
    letter-spacing: -2px;
    text-transform: uppercase;
}

/* Hero paragraph */
.hero-text {
    font-size: 16px;
    color: #555555;
    max-width: 650px;
    margin: 20px auto;
}

/* Premium buttons */
.btn-premium {
    background-color: #111111;
    color: #ffffff;
    border-radius: 0;
    padding: 12px 28px;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    border: 1px solid #111111;
}

/* Button hover */
.btn-premium:hover {
    background-color: #ffffff;
    color: #111111;
    border: 1px solid #111111;
}

/* Category section */
.category-section {
    padding: 60px 0 90px 0;
}

/* Category grid spacing */
.category-section .row {
    row-gap: 28px;
}

/* Category link */
.category-link {
    display: block;
    color: #ffffff;
    text-decoration: none;
}

/* Category image card */
.category-card {
    height: 420px;
    background-color: #111111;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    color: #ffffff;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease;
}

/* Desktop hover */
.category-card:hover {
    transform: scale(1.015);
}

/* Dark overlay */
.category-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to top,
            rgba(0, 0, 0, 0.75),
            rgba(0, 0, 0, 0.15));
    z-index: 1;
}

/* Category text placement */
.category-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding-bottom: 35px;
}

/* Category title */
.category-content h3 {
    font-size: 34px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 8px;
}

/* Shop now text */
.category-content span {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    border-bottom: 1px solid #ffffff;
    padding-bottom: 3px;
}

/* Mobile category fix */
@media (max-width: 768px) {
    .category-card {
        height: 260px;
    }

    .category-content h3 {
        font-size: 26px;
    }
}

/* Shop now */
.category-content span {
    font-size: 12px;
    text-transform: uppercase;
    text-decoration: underline;
}

/* Product cards */
.product-card {
    border: none;
    border-radius: 0;
    box-shadow: none;
    background-color: #ffffff;
}

/* Product image */
.product-card img {
    height: 330px;
    object-fit: cover;
    border-radius: 0;
}

/* Product title */
.product-card .card-title {
    font-size: 15px;
    font-weight: 700;
    text-transform: uppercase;
}

/* Product text */
.product-card .card-text,
.product-card p {
    font-size: 13px;
    color: #444444;
}

/* Forms */
.card {
    border-radius: 0;
    border: 1px solid #e5e5e5;
}

/* Inputs */
.form-control {
    border-radius: 0;
    border: 1px solid #cccccc;
}

/* Tables */
.table {
    font-size: 14px;
}

/* Shop button */
.btn-shop {
    background-color: #111111;
    color: #ffffff;
    border: 1px solid #111111;
    border-radius: 0;
    padding: 10px 22px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1px;
    width: 100%;
}

/* Shop button hover */
.btn-shop:hover {
    background-color: #ffffff;
    color: #111111;
    border: 1px solid #111111;
}

/* Mobile responsiveness */
@media (max-width: 768px) {
    .hero-title {
        font-size: 36px;
    }

    .custom-navbar .nav-link {
        text-align: center;
        margin: 8px 0;
    }

    .navbar-logo {
        font-size: 18px;
    }

    .category-card {
        height: 260px;
    }
}

.site-footer {
    background-color: #111111;
    color: #ffffff;
    padding: 50px 0 25px 0;
    font-size: 14px;
}

.site-footer h5 {
    text-transform: uppercase;
    font-size: 14px;
    letter-spacing: 1px;
    margin-bottom: 15px;
}

.site-footer p {
    color: #cccccc;
}

.site-footer a {
    color: #ffffff;
    text-decoration: none;
    font-size: 13px;
}

.site-footer a:hover {
    color: #007a4d;
}

.site-footer hr {
    border-color: #333333;
}

/* Keep the navigation bar visible while scrolling */
.custom-navbar {
    position: sticky;
    top: 0;
    z-index: 1030;
    background-color: #ffffff;
}

.seller-contact {
    margin-top: 10px;
    padding-top: 10px;
    border-top: 1px solid #dddddd;
    font-size: 14px;
}

.seller-contact p {
    margin-bottom: 4px;
}

.seller-contact a {
    color: #111111;
    text-decoration: none;
}

.seller-contact a:hover {
    text-decoration: underline;
}

.seller-contact-box {
    margin: 20px 0;
    padding: 18px;
    border: 1px solid #dddddd;
    background-color: #f8f8f8;
}

.seller-contact-box h6 {
    margin-bottom: 12px;
    font-weight: 700;
}
/* Shopping cart and product detail additions */
.cart-product-image {
    width: 72px;
    height: 72px;
    object-fit: cover;
    border: 1px solid #e5e5e5;
}

.product-detail-image {
    width: 100%;
    max-height: 620px;
    object-fit: cover;
}

.cart-table td,
.cart-table th {
    vertical-align: middle;
}

@media (max-width: 768px) {
    .cart-product-image {
        width: 56px;
        height: 56px;
    }
}
